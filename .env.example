# Copy this file to .env and fill in values (never commit .env to GitHub)

# Required for production — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Local development only (optional — users can enter key in the UI for AI mode)
OPENAI_API_KEY=

# Set to false in production
FLASK_DEBUG=true
FLASK_ENV=development

# Optional: PostgreSQL on Render/Railway (leave empty to use SQLite in instance/)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Max PDF upload size per request (megabytes)
MAX_UPLOAD_MB=16

# Guest free screenings before sign-up (default: 2)
# GUEST_FREE_ATTEMPTS=2

# Email verification (Gmail: use App Password, not normal password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your.email@gmail.com
VERIFICATION_CODE_MINUTES=15
